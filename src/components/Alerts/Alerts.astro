---
import { X } from "@lucide/astro";

import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/config";

const t = useTranslations(Astro.currentLocale as Locale);
---

<ares-alerts>
  <template data-js="template">
    <div class="alert" role="alert" data-js="wrapper">
      <button
        type="button"
        class="alert-close"
        title={t("Labels.close")}
        data-js="button"
      >
        <X />
      </button>
      <div data-js="content"></div>
    </div>
  </template>
  <div class="visually-hidden" aria-live="assertive" aria-atomic="true"></div>
  <div class="visually-hidden" aria-live="polite" aria-atomic="true"></div>
</ares-alerts>

<style>
  .alert {
    align-items: center;
    animation: slide-in 500ms;
    background: var(--bg-color-alert);
    border-left: 7px solid #000;
    border-radius: 5px;
    bottom: 5rem;
    box-shadow: 0 0 6px rgb(0 0 0 / 20%);
    color: var(--color-text);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.8em;
    gap: 1rem;
    line-height: 1.3;
    margin-left: 10px;
    max-width: calc(100% - 2rem);
    padding: 20px;
    padding-right: 2rem;
    position: fixed;
    right: 1rem;
    transition: all 0.3s;
    width: 550px;
    z-index: 100000;
  }

  .alert.hide {
    animation: slide-out 500ms;
    opacity: 0;
    visibility: hidden;
  }

  .alert.big {
    font-size: 1rem;
    width: auto;
  }

  .alert.update {
    justify-content: center;
    z-index: 100001;
  }

  .alert-close {
    align-items: center;
    background-color: transparent;
    border: none;
    color: var(--color-text);
    display: flex;
    font-size: 1.2em;
    height: 20px;
    justify-content: center;
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
  }

  .alert .close:hover {
    color: #000;
  }

  .alert p {
    padding-right: 20px;
  }

  .alert.alert--info {
    border-color: #14213d;
  }

  .alert.alert--danger {
    border-color: #f0192a;
  }

  .alert.alert--success {
    border-color: #3bae59;
  }

  @media (prefers-reduced-motion) {
    .alert {
      animation: none;
      transition: none;
    }

    .alert.hide {
      animation: none;
    }
  }
</style>
