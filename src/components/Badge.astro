---
import { Image } from "astro:assets";

interface Props {
  small?: boolean;
  size: number;
  icon: ImageMetadata;
  title: string;
}

const { icon, size, title, small } = Astro.props;
---

<div class={`badge ${small ? "badge--small" : ""}`}>
  <Image class="badge__icon" src={icon} alt="" height={size} width={size} />
  <span class="badge__label">{title}</span>
</div>

<style is:global>
  .badge {
    align-items: center;
    background-color: #121212;
    border-radius: 1rem;
    box-shadow: 0 4px 6px rgb(0 0 0 / 10%);
    color: var(--color-text);
    cursor: default;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    justify-content: center;
    padding: 1rem 2rem;
    text-align: center;
  }

  .badge__icon {
    margin: auto 0;
  }

  .badge__label {
    font-size: 1.25rem;
  }

  .theme-light .badge__label {
    color: var(--color-text-dark);
  }

  .badge--small {
    flex-direction: row;
    height: 4.7rem;
    padding: 0.5rem 1.5rem;
  }

  .badge--small .badge__icon {
    height: 2rem;
    width: 2rem;
  }

  @media (width < 992px) {
    .badge {
      flex-direction: row;
      padding: 0.5rem 1rem;
    }

    .badge .badge__icon {
      height: 2rem;
      width: 2rem;
    }
  }
</style>
