---
interface Props {
  id?: string;
  labelledById?: string;
}

const { labelledById, id } = Astro.props;
---

<ares-carousel class="embla" id={id}>
  <ul class="embla__container" aria-labelledby={labelledById}>
    <slot />
  </ul>
</ares-carousel>

<style>
  .embla {
    overflow: hidden;
    width: 100%;
  }

  .embla__container {
    display: flex;
  }

  .embla__slide {
    flex: 0 0 100%;
    min-width: 0;
  }
</style>
