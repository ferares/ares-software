---
import type { Locale } from "../../i18n/config";
import { useTranslations } from "../../i18n/utils";

const t = useTranslations(Astro.currentLocale as Locale);
---

<ares-menu-toggle>
  <button
    type="button"
    aria-controls="main-menu"
    data-js="button"
    aria-expanded="false"
    aria-label={t("Labels.open-menu")}
    class="menu-toggle-btn"
  >
    <span class="icon-hamburger">
      <span class="icon-hamburger__line"></span>
      <span class="icon-hamburger__line"></span>
      <span class="icon-hamburger__line"></span>
    </span>
  </button>
</ares-menu-toggle>

<style>
  .menu-toggle-btn {
    background-color: transparent;
    border: 0;
    display: flex;
    height: 1.1rem;
    padding: 0;
    width: 1.4rem;
  }

  .icon-hamburger {
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: space-between;
    width: 100%;
  }

  .icon-hamburger__line {
    background-color: var(--color-text);
    height: 0.1rem;
    transition: all 0.3s;
    width: 100%;
  }

  .menu-toggle-btn.open .icon-hamburger__line:nth-child(1) {
    transform: translateY(0.5rem) rotate(-45deg);
  }

  .menu-toggle-btn.open .icon-hamburger__line:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle-btn.open .icon-hamburger__line:nth-child(3) {
    transform: translateY(-0.4rem) rotate(45deg);
  }

  @media (prefers-reduced-motion) {
    .icon-hamburger__line {
      transition: none;
    }
  }
</style>
