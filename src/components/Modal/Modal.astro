---
import { X } from "@lucide/astro";

import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/config";

interface Props {
  id: string;
  className?: string;
}

const { id, className } = Astro.props;
const t = useTranslations(Astro.currentLocale as Locale);
---

<ares-modal id={id}>
  <dialog data-js="dialog" class={`modal ${className ?? ""}`}>
    <div class="modal__content" data-js="content">
      <button
        type="button"
        class="modal__close"
        aria-label={t("Labels.close")}
        data-js="close"
      >
        <X />
      </button>
      <div class="modal__header" data-js="header">
        <slot name="title" />
      </div>
      <div class="modal__body" data-js="body">
        <slot />
      </div>
    </div>
  </dialog>
</ares-modal>

<style>
  .modal {
    background: transparent;
    border: 0;
    height: 100%;
    margin: 0;
    max-height: 100%;
    max-width: 100%;
    opacity: 1;
    transition: all 0.3s;
    width: 100%;
  }

  .modal[open] {
    align-items: center;
    display: flex;
    justify-content: center;
  }

  .modal.hide {
    opacity: 0;
  }

  .modal.hide::backdrop {
    animation: background-fade-out 0.3s ease;
    background: transparent;
  }

  .modal[open]::backdrop {
    animation: background-fade-in 0.3s ease;
    background: rgb(0 0 0 / 60%);
  }

  .modal__content {
    background: var(--bg-color-modal);
    border-radius: 10px;
    box-shadow: 0 0 6px rgb(0 0 0 / 20%);
    display: flex;
    flex-direction: column;
    height: auto;
    max-height: 90%;
    max-width: 70rem;
    overflow-y: auto;
    padding: 1rem;
    position: relative;
    width: 100%;
  }

  .modal__close {
    background-color: transparent;
    border: none;
    color: var(--color-text);
    font-size: 1.6em;
    margin-left: auto;
    padding: 0;
    position: sticky;
    text-align: center;
    top: 0;
    z-index: 10;
  }

  .modal__header {
    margin-top: -1rem;
  }

  .modal__title {
    font-family: var(--font-texts);
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1;
    margin-bottom: 2rem;
    text-align: center;
  }

  .modal .modal__content::-webkit-scrollbar {
    height: 4px;
    width: 4px;
  }

  .modal .modal__content::-webkit-scrollbar-track {
    background-color: transparent;
  }

  .modal .modal__content::-webkit-scrollbar-thumb {
    background-color: #ccc;
    border: none;
    border-radius: 5px;
  }

  .modal .modal__content::-webkit-scrollbar-thumb:hover {
    background-color: #ccc;
  }

  .modal .action-buttons {
    border-top: 1px solid #ccc;
    display: flex;
    justify-content: flex-end;
    margin-top: 10px;
    padding: 10px 30px;
  }

  .modal .action-buttons .btn {
    margin-left: 10px;
  }

  @media (prefers-reduced-motion) {
    .modal.hide::backdrop,
    .modal[open]::backdrop {
      animation: none;
    }
  }
</style>
