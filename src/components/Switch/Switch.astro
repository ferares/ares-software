---
interface Props {
  id?: string;
  className?: string;
  ariaLabels?: { left: string; right: string };
}
const { className, ariaLabels, id } = Astro.props;
---

<ares-switch
  id={id}
  data-label-right={ariaLabels?.right}
  data-label-left={ariaLabels?.left}
>
  <button
    type="button"
    class={`switch ${className ?? ""}`}
    aria-label={ariaLabels?.left}
    data-js="toggle"
  >
    <span class="switch__indicator switch__indicator--left" data-js="indicator">
      <span class="switch__indicator__icon-wrapper">
        <slot name="icon-left" />
      </span>
      <span class="switch__indicator__icon-wrapper">
        <slot name="icon-right" />
      </span>
    </span>
  </button>
</ares-switch>

<style>
  .switch {
    align-items: center;
    background-color: var(--color-text-dark);
    border: 0;
    border-radius: 30px;
    color: var(--color-text-dark);
    font-size: 1.5rem;
    line-height: 1;
    padding: 0.5rem 1rem;
    width: 6.8rem;
  }

  .theme-light .switch {
    background-color: var(--color-text);
    color: var(--color-text);
  }

  .theme-light .switch__indicator {
    background-color: var(--color-text-dark);
  }

  .switch__indicator {
    align-items: center;
    background-color: var(--color-text);
    border-radius: 50%;
    display: flex;
    height: 2.4rem;
    justify-content: center;
    transition: all 0.5s;
    width: 2.4rem;
  }

  .switch__indicator--right {
    transform: translateX(100%);
  }

  .switch__indicator__icon-wrapper {
    align-items: center;
    display: flex;
    justify-content: center;
  }

  .switch__indicator .switch__indicator__icon-wrapper:first-child {
    display: none;
  }

  .switch__indicator--right .switch__indicator__icon-wrapper:first-child {
    display: flex;
  }

  .switch__indicator--right .switch__indicator__icon-wrapper:last-child {
    display: none;
  }

  .switch__indicator--right .switch__indicator {
    background-color: var(--color-text-dark);
  }

  @media (prefers-reduced-motion) {
    .switch__indicator {
      transition: none;
    }
  }
</style>
