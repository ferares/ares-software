---
import { Image } from "astro:assets";

import { Link } from "@lucide/astro";

import { clientProjects, personalProjects } from "../../../constants/projects";
import { technologies } from "../../../constants/technologies";

import { locales, type Locale } from "../../../i18n/config";
import { useTranslations } from "../../../i18n/utils";

import Badge from "../../../components/Badge.astro";
import VideoPlayer from "../../../components/VideoPlayer/VideoPlayer.astro";

import GitHubLogoLight from "../../../assets/github_light.svg";

export const partial = true;

export function getStaticPaths() {
  const projects = clientProjects.concat(personalProjects);
  return locales.flatMap((lang) =>
    projects.map((project) => ({
      params: { lang, id: project.id },
      props: { project },
    })),
  );
}

const { project } = Astro.props;

const t = useTranslations(Astro.currentLocale as Locale);
---

<VideoPlayer videos={project.videos} />
<p class="project__paragraph">{t(project.desc)}</p>
<div id={`project-${project.id}-links`} class="project__links">
  {
    project.links.map((link) => (
      <a
        class="project__btn btn"
        href={link.url}
        target="_blank"
        rel={link.rel ?? "noopener noreferrer nofollow"}
      >
        {t(link.label)}
        {link.gitHub ? (
          <Image class="project__btn__img" src={GitHubLogoLight} alt="" />
        ) : (
          <Link />
        )}
      </a>
    ))
  }
</div>
{
  project.stores && (
    <ul class="project__stores">
      {project.stores.apple && (
        <li class="project__store">
          <a
            class="project__store__link"
            href={project.stores.apple}
            target="_blank"
          >
            <img
              class="project__store__img"
              src={t("Stores.apple.image")}
              alt={t("Stores.apple.label")}
            />
          </a>
        </li>
      )}
      {project.stores.google && (
        <li class="project__store">
          <a
            class="project__store__link"
            href={project.stores.google}
            target="_blank"
          >
            <img
              class="project__store__img"
              src={t("Stores.google.image")}
              alt={t("Stores.google.label")}
            />
          </a>
        </li>
      )}
      {project.stores.microsoft && (
        <li class="project__store">
          <a
            class="project__store__link"
            href={project.stores.microsoft}
            target="_blank"
          >
            <img
              class="project__store__img"
              src={t("Stores.microsoft.image")}
              alt={t("Stores.microsoft.label")}
            />
          </a>
        </li>
      )}
    </ul>
  )
}
<h3 class="project__tech-title">{t("Labels.developed-using")}</h3>
<ul class="project__technologies">
  {
    project.technologies.map((tech) => {
      const technology = technologies[tech];
      return (
        <li>
          <Badge
            icon={technology.icon}
            size={technology.iconSize}
            title={technology.title}
            small
          />
        </li>
      );
    })
  }
</ul>

<style is:inline>
  .project__paragraph {
    color: var(--color-text);
    margin: 2rem auto;
    max-width: 50rem;
  }

  .project__tech-title {
    font-family: var(--font-texts);
    font-size: 1.5rem;
    margin-bottom: 2rem;
  }

  .project__technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .project__links {
    display: flex;
    gap: 1rem;
    margin: 0 auto;
    margin-bottom: 2rem;
    max-width: 500px;
  }

  .project__btn {
    align-items: center;
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    width: 100%;
  }

  .project__btn .small {
    font-size: 1.1rem;
  }

  .project__btn__img {
    height: auto;
    width: 30px;
  }

  .project__stores {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-inline: auto;
  }

  .project__store__img {
    height: 70px;
    width: 100%;
  }

  @media (width < 768px) {
    .project__links {
      flex-direction: column;
    }
  }
</style>
