---
import { Mail } from "@lucide/astro";

import { clientProjects, personalProjects } from "../constants/projects";

import type { Locale } from "../i18n/config";
import { useTranslations } from "../i18n/utils";

import ProjectsList from "../components/ProjectsList/ProjectsList.astro";
import ContactButton from "../components/ContactButton/ContactButton.astro";

const t = useTranslations(Astro.currentLocale as Locale);
---

<section id="projects" class="projects">
  <h2 class="section-title">{t("Sections.Projects.title")}</h2>
  <p class="projects__intro">{t("Sections.Projects.intro")}</p>
  <div class="projects__content">
    <ProjectsList
      id="projects-personal"
      title={t("Sections.Projects.personal-projects.title")}
      intro={t("Sections.Projects.personal-projects.intro")}
      projects={personalProjects}
    />
    <ProjectsList
      id="projects-client"
      title={t("Sections.Projects.client-projects.title")}
      intro={t("Sections.Projects.client-projects.intro")}
      projects={clientProjects}
    />
  </div>
  <div class="projects__contact">
    <ContactButton>
      <span class="btn projects__btn">
        <Mail />
        {t("Labels.contact-me")}
      </span>
    </ContactButton>
  </div>
</section>

<style>
  .projects {
    background-color: var(--bg-color-projects);
    padding: 2rem 0;
  }

  .projects .section-title {
    margin-bottom: 1rem;
  }

  .projects__intro {
    margin-bottom: 2rem;
    text-align: center;
  }

  .projects__content {
    height: 100%;
  }

  .projects__contact {
    display: flex;
    justify-content: center;
    padding: 0 2rem;
  }

  .projects__btn {
    display: flex;
    gap: 1rem;
  }

  @media (width < 576px) {
    .projects {
      padding: 2rem 0;
    }

    .projects .section-title {
      font-size: 2.5rem;
      line-height: 1.3;
      margin-bottom: 1.5rem;
    }
  }
</style>
